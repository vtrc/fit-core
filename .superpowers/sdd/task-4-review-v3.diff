+  plannedRepetitions: number | null;
+  plannedWeight: number | null;
+  plannedDurationSeconds: number | null;
+  plannedDistance: number | null;
+  restSeconds: number | null;
+  notes: string;
+}
+
+interface RoutineDraft {
