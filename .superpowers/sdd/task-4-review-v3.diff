+      <header class="hero">
+        <div>
+          <p class="eyebrow">{{ isEditMode() ? 'EDIT ROUTINE' : 'NEW ROUTINE' }}</p>
+          <h1>{{ isEditMode() ? 'Refine your plan.' : 'Build a reusable routine.' }}</h1>
+          <p class="lede">Pick exercises from the shared catalog, order them, and define the targets you care about.</p>
+        </div>
+        <div class="hero-actions">
+          <a routerLink="/routines">Back to routines</a>
+          @if (isEditMode()) {
+            <a [routerLink]="['/routines', routineId()]">View detail</a>
+          }
+        </div>
+      </header>
+
+      @if (loading()) {
+        <section class="card state"><p>Loading routine editor…</p></section>
+      } @else {
+        <div class="layout">
+          <section class="card editor">
+            @if (saveError(); as errorMessage) {
+              <p class="banner error" role="alert">{{ errorMessage }}</p>
+            }
+
+            @if (validationErrors().length > 0 && attemptedSubmit()) {
+              <div class="banner error" role="alert">
+                <p>Fix these issues before saving:</p>
+                <ul>
+                  @for (errorMessage of validationErrors(); track errorMessage) {
+                    <li>{{ errorMessage }}</li>
+                  }
+                </ul>
