+            }
+
+            <label class="field">
+              <span>Name</span>
+              <input
+                type="text"
+                [ngModel]="draft().name"
+                (ngModelChange)="updateDraftText('name', $event)"
+                placeholder="Upper / lower split"
+              />
+            </label>
+
+            <label class="field">
+              <span>Description</span>
+              <textarea
+                rows="3"
+                [ngModel]="draft().description"
+                (ngModelChange)="updateDraftText('description', $event)"
+                placeholder="Optional notes about intent, tempo, or focus."
+              ></textarea>
+            </label>
+
+            <section class="selected">
+              <div class="section-heading">
+                <h2>Selected exercises</h2>
+                <p>{{ draft().exercises.length }} planned</p>
+              </div>
+
+              @if (draft().exercises.length === 0) {
+                <div class="empty-inline"><p>Add at least one exercise from the catalog.</p></div>
+              } @else {
+                <div class="exercise-list">
+                  @for (item of draft().exercises; track trackExercise($index, item.exercise.id)) {
+                    <article class="exercise-card">
+                      <div class="exercise-header">
+                        <div>
+                          <p class="eyebrow">{{ item.exercise.type }}</p>
