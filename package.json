{
  "name": "fit-core",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy:angular": "ng build && npx @insforge/cli deployments deploy .",
    "build:functions:all": "node scripts/build-functions.mjs",
    "deploy:functions:all": "npm run build:functions:all && for d in functions/*/; do n=$(basename \"$d\"); npx @insforge/cli functions deploy \"$n\" --file \"functions/$n.ts\" --name \"$n\"; done",
    "deploy:all": "npm run deploy:angular && npm run deploy:functions:all"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.11",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@insforge/sdk": "^1.4.4",
    "ai": "^7.0.29",
    "marked": "^18.0.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
